{
  "expo": {
    "name": "Quiet Alarm",
    "slug": "quiet-alarm",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "quietalarm",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.quietalarm.app",
      "supportsTablet": true,
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "UIBackgroundModes": [
          "audio"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "Quiet Alarm does not record audio. This permission is only required by an audio library dependency and is never used."
      }
    },
    "android": {
      "predictiveBackGestureEnabled": false,
      "package": "com.quietalarm.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0a0906",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "18973cd1-a335-4ac9-9333-fd03cf0411b9"
      }
    }
  }
}
