{
  "name": "@biosyncare/audio-engine",
  "version": "0.1.0",
  "description": "BioSynCare custom C++ audio DSP nodes (Martigli / binaural / symmetry / noise) as a reusable React Native New-Architecture Turbo Module built on top of react-native-audio-api, with a shared DSP core that also compiles to WASM for the web AudioWorklet.",
  "main": "src/index.ts",
  "react-native": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src",
    "cpp",
    "ios",
    "android/build.gradle",
    "android/CMakeLists.txt",
    "android/src",
    "scripts",
    "patches",
    "AudioEngine.podspec",
    "react-native.config.js",
    "README.md",
    "INTEGRATION.md",
    "!android/build",
    "!**/.cxx",
    "!**/*.log"
  ],
  "scripts": {
    "test:dsp": "bash ./scripts/testSharedDsp.sh",
    "wasm:build": "node ./scripts/buildWorkletWasm.js",
    "wasm:check": "node ./scripts/checkWorkletWasm.js"
  },
  "codegenConfig": {
    "name": "AudioApiTurboModules",
    "type": "modules",
    "jsSrcsDir": "src/specs",
    "android": {
      "javaPackageName": "com.biosyncare.audioengine"
    },
    "ios": {
      "modulesProvider": {
        "NativeCustomNodesModule": "NativeCustomNodesModuleProvider"
      }
    }
  },
  "dependencies": {
    "events": "^3.3.0"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": ">=0.81.0",
    "react-native-audio-api": ">=0.7.0 <0.9.0",
    "react-native-worklets": ">=0.5.0",
    "react-native-reanimated": ">=4.0.0"
  },
  "license": "UNLICENSED",
  "private": false
}
